# ============================================================
#  Interview-Success Recording Portal — configuration
#  Copy this file to ".env" and edit. Never commit the real .env.
# ============================================================

# ---- App ----
# Generate a random one for production:  python -c "import secrets;print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-long-random-string
PORT=8000
FLASK_DEBUG=0

# ---- Admin activity log ----
# SQLite file used for login/search/view/download audit events.
# 0 disables age-based cleanup; the row cap below still applies.
AUDIT_DB=audit.db
AUDIT_RETENTION_DAYS=180
# Hard size guard. Oldest rows are removed after this many retained events.
AUDIT_MAX_ROWS=100000

# ---- Admins (plaintext, comma-separated user:password pairs) ----
# These accounts can open the Admin page and create normal users.
# Add as many as you want, separated by commas.
ADMIN_USERS=naman:NamanPass123,parth:ParthPass123

# ---- S3 ----
S3_BUCKET_NAME=zoom-automation-bucket
ROOT_PREFIX=Interview-Success/
AWS_REGION=us-east-1
CACHE_TTL_SEC=300
PRESIGNED_URL_EXPIRY_SEC=3600
# Temporary bulk ZIP safety limits (250 files / 10 GiB by default).
BULK_ZIP_MAX_FILES=250
BULK_ZIP_MAX_BYTES=10737418240

# ---- Departments ----
# Top-level folders in the bucket, each with the same {Host}/{Year}/.../{Candidate}
# layout inside. The portal scans every one and tags each recording with its
# department; admins then grant each user one or more departments (+ view/download)
# on the Admin page. Comma-separated, must match the S3 folder names exactly.
DEPARTMENTS=HR,Interview-Success,Marketing,Training,Customer-Success,Techsphere,Executive-Assistant,QMS,Other,CEO,COO,Business-Development,Advanced-Training

# ---- Local testing without AWS ----
# true  = serve bundled sample data so you can test the whole UI offline.
# false = talk to the real S3 bucket (needs AWS credentials, see README).
DEMO_MODE=true

# ---- AWS credentials (LOCAL ONLY) ----
# On EC2 do NOT set these — attach an IAM role instead (see README).
# For local testing against real S3, either run `aws configure` or uncomment:
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...

# ---- gunicorn tuning (Docker only, optional) ----
# Use 2 workers on a t3.micro (1 GB RAM); 3 is fine on t3.small (2 GB).
# GUNICORN_WORKERS=3
# GUNICORN_THREADS=4
