{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ListBucketForPortal",
      "Effect": "Allow",
      "Action": "s3:ListBucket",
      "Resource": "arn:aws:s3:::zoom-automation-bucket"
    },
    {
      "Sid": "ReadInterviewSuccessObjects",
      "Effect": "Allow",
      "Action": "s3:GetObject",
      "Resource": "arn:aws:s3:::zoom-automation-bucket/Interview-Success/*"
    }
  ]
}
